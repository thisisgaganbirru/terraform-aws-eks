# Terraform state files
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Variable files with sensitive data
*.tfvars
!environments/**/*.tfvars
!environments/**/*.tfvars.example

# Crash log files
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# keep lockfile in version control
!.terraform.lock.hcl

# SSH private keys
*.pem

# terraform plan output files
*.tfplan
*.tfstate.backup