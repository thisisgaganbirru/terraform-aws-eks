# Terraform state files
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Variable files with sensitive data
*.tfvars
!terraform.tfvars.example
!envs/*.tfvars

# Crash log files
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# keep lockfile in version control
!.terraform.lock.hcl

# terraform plan output files
*.tfplan
*.tfstate.backup